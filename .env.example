# --- Email alerts (optional but recommended) ---
# Leave SMTP_* blank to disable email; new ads will still show in the dashboard.
# For Gmail: create an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
ALERT_TO=aj01dude@gmail.com
ALERT_FROM=AdMonitor <you@gmail.com>

# --- Dashboard ---
PORT=8080

# --- Scraper ---
# Max seconds to keep scrolling per competitor to load lazy-loaded ads
SCRAPE_SCROLL_SECONDS=25
# Set to "false" to watch the browser while debugging
HEADLESS=true
